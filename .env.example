# Google OAuth 設定（Google Cloud Console で取得）
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# OAuth リダイレクト URI（Google Cloud Console に登録したURIと一致させること）
VITE_GOOGLE_REDIRECT_URI=https://hirag-62.github.io/Maillet/

# NOTE: GOOGLE_CLIENT_SECRET はフロントに含めない。
# Netlify環境変数として GOOGLE_CLIENT_SECRET を設定すること（Netlify管理画面 > Site settings > Environment variables）。
